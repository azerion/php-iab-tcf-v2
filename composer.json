{
    "name": "azerion/iab-tcf-v2",
    "description": "IAB TCF v2.x consent string decoder and encoder for PHP.",
    "type": "library",
    "license": "Apache-2.0",
    "keywords": ["iab", "tcf", "tcf-v2", "gdpr", "consent", "consent-string"],
    "homepage": "https://github.com/azerion/php-iab-tcf-v2",
    "require": {
        "php": "^8.3"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^2.0",
        "laravel/pint": "^1.18"
    },
    "autoload": {
        "psr-4": {
            "Azerion\\IabTcf\\V2\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Azerion\\IabTcf\\V2\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse",
        "pint": "pint",
        "pint-check": "pint --test",
        "ci": ["@pint-check", "@phpstan", "@test"]
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
